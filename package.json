{
  "name": "verboo-goal-plugin",
  "version": "0.2.0",
  "private": true,
  "description": "Persistent, budget-aware /goal loops for Verboo Code.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "check": "bun run typecheck && bun run lint && bun run build && bun run validate:versions && bun run validate:plugin-offline && bun test",
    "lint": "eslint src test scripts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "validate:plugin": "verboo plugin validate .",
    "validate:plugin-offline": "bun scripts/validate-plugin-contract.ts",
    "validate:versions": "bun scripts/check-versions.ts",
    "dev:plugin": "verboo --plugin-dir .",
    "dev:mcp": "verboo --mcp-config .mcp.dev.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/bun": "1.3.14",
    "@types/node": "22.20.1",
    "eslint": "10.6.0",
    "globals": "17.7.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0"
  }
}
